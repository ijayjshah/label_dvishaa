# Copy to ".env" in the repo root (required for `pnpm dev` / `dotenv -e .env -- ...`).
# Values are loaded by: DB package, Drizzle, Vite loadEnv + envDir, and dev scripts via dotenv-cli.

# --- PostgreSQL (required for API + migrations) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/figma_design_tracker

# --- API (Express) — listen port ---
API_PORT=3001

# Single PORT is still supported (e.g. Replit): used if API_PORT is unset.
# PORT=3001

# --- Web app (Vite dev) — use API_PORT + FRONTEND_PORT together locally ---
FRONTEND_PORT=5173
# Optional: exact SPA URL for API browser hints and /admin redirect (defaults to http://127.0.0.1:FRONTEND_PORT)
# WEB_APP_URL=http://localhost:5173
BASE_PATH=/

# Vite proxies browser requests "/api/*" to this origin in dev.
API_SERVER_URL=http://127.0.0.1:3001

# Production frontend (Vercel): API origin only — no trailing slash, no /api suffix.
# Example: https://label-dvisha-api.onrender.com
# VITE_API_BASE_URL=https://your-api-host.example.com

# Browser origins allowed to call the API (comma-separated). Omit for wide-open dev default.
# Use * to allow any Origin (reflect). Prefer explicit URLs in production.
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# --- Cloudinary (required for Browse image uploads from the app) ---
# Dashboard: https://cloudinary.com/console — use API Key + API Secret + Cloud name.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional folder prefix in your Cloudinary account (default: label-dvisha)
# CLOUDINARY_UPLOAD_FOLDER=label-dvisha

# --- Razorpay (checkout needs Key ID + Secret only) ---
# Dashboard: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
# Optional — only if you set up webhooks in Razorpay Dashboard (not required for checkout).
# After creating a webhook, Razorpay shows the secret once. Endpoint: https://your-api-host/api/webhooks/razorpay
# RAZORPAY_WEBHOOK_SECRET=

# --- Optional ---
SESSION_SECRET=change-me-in-production

# Initial admin (optional overrides for `pnpm db:seed:admin` / full `pnpm db:seed`)
# After changing email/password, run: pnpm db:reset:admin
# SEED_ADMIN_EMAIL=labeldvisha4345@gmail.com
# SEED_ADMIN_PASSWORD=your-secure-password
# SEED_ADMIN_NAME=Admin
# SEED_ADMIN_PHONE=7990414960
